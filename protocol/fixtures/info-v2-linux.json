{
  "agent": {
    "instanceId": "55555555555555555555555555555555",
    "displayName": "Fixture Linux Player",
    "version": "0.1.0-beta.1",
    "platform": "linux",
    "architecture": "x64"
  },
  "capabilities": [
    "players.list",
    "sessions.create",
    "sessions.status",
    "sessions.control",
    "sessions.end-reasons"
  ],
  "acceptedPathKinds": ["linux-absolute"],
  "maxConcurrentSessions": 1,
  "defaultPlayerId": "mpv",
  "players": [
    {
      "id": "mpv",
      "kind": "mpv",
      "name": "mpv",
      "available": true,
      "capabilities": [
        "play.file",
        "fullscreen",
        "status.state",
        "status.position",
        "status.duration",
        "control.pause",
        "control.seek",
        "control.stop"
      ]
    }
  ]
}
